

func divide(a, b) { if (b == 0) { print("Error: division by zero!"); return 0; } return a / b; } print("=== CLV Console Calculator ==="); print("Enter the first number:"); let a = input_num(); print("Enter the second number:"); let b = input_num(); print("Sum: " + to_str(a + b)); print("Difference: " + to_str(a - b)); print("Product: " + to_str(a * b)); print("Quotient: " + to_str(divide(a, b))); print("Press Enter to exit..."); let dummy = input();
